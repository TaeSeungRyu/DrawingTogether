<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!-- 카메라 촬영 결과를 임시 저장할 캐시 영역. -->
    <cache-path name="camera_captures" path="captures/" />
    <!-- "동기화" 시 bitmap → JPEG 변환 임시 파일을 두는 캐시 영역. -->
    <cache-path name="snapshots" path="snapshots/" />
    <!-- 저장된 작품 PNG 공유용. WorkStore.shareUriFor 가 FileProvider URI 생성. -->
    <files-path name="works" path="works/" />
</paths>
